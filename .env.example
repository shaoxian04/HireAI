# HireAI backend — environment template.
# Copy to a local .env (git-ignored) and fill in real values, OR set these as OS
# environment variables before `mvn spring-boot:run`. Spring Boot resolves
# ${DB_URL} / ${DB_USERNAME} / ${DB_PASSWORD} from the OS environment.
#
# NOTE: Spring Boot does NOT auto-load .env files. On Windows PowerShell, export
# them for the current shell before running:
#   $env:DB_URL="..."; $env:DB_USERNAME="..."; $env:DB_PASSWORD="..."; mvn spring-boot:run

# ---------------------------------------------------------------------------
# Database — Supabase (hosted Postgres)
# ---------------------------------------------------------------------------
# Get these from the Supabase dashboard: Project → Connect → "Session pooler".
#
# IMPORTANT: use the SESSION pooler (port 5432), NOT the transaction pooler
# (port 6543). Flyway migrations use advisory locks + DDL transactions that break
# under transaction pooling. SSL is required, so keep ?sslmode=require.
#
# The pooler username is "postgres.<your-project-ref>".
DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.<your-project-ref>
DB_PASSWORD=<your-database-password>

# For a local Docker Postgres instead (optional), the defaults baked into
# application.yml are:
#   DB_URL=jdbc:postgresql://localhost:5432/hireai
#   DB_USERNAME=hireai
#   DB_PASSWORD=hireai
